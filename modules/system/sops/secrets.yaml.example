# Example secrets structure — copy to secrets.yaml and encrypt with sops.
#
# Create the actual file:
#   cp modules/system/sops/secrets.yaml.example modules/system/sops/secrets.yaml
#   fill in real values, then encrypt:
#   sops --encrypt --in-place modules/system/sops/secrets.yaml
#
# The age key used for encryption is set in .sops.yaml.

cloudflare_token: "your-cloudflare-api-token"
cloudflare_email: "you@example.com"

k3s_token: "a-long-random-string-for-k3s-cluster-auth"

pihole_password: "pihole-admin-password"

# WireGuard server keys — generate with: wg genkey | tee server.key | wg pubkey > server.pub
wireguard_server_private_key: "server-private-key"
wireguard_server_public_key: "server-public-key"
wireguard_server_endpoint: "your-public-ip-or-ddns-hostname"

# Nextcloud
nextcloud_admin_password: "nextcloud-admin-password"
nextcloud_admin_username: "admin"
nextcloud_db_password: "db-password"
nextcloud_db_username: "nextcloud"
nextcloud_redis_password: "redis-password"

# Linux user password — generate hash with: mkpasswd -m sha-512
user_password: "$6$..."

# SSH private key to deploy to the node (base64 or literal key)
private_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  ...
  -----END OPENSSH PRIVATE KEY-----

# WireGuard user public keys — one entry per enabled user in vars.nix wireguardUsers.
# The key name must match the publicKeySecret field for each user.
# alice_wg_public_key: "alice-wg-public-key"
# bob_wg_public_key: "bob-wg-public-key"
